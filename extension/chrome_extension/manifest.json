{
  "manifest_version": 3,
  "name": "KillZBot Control Panel",
  "version": "1.4.0",
  "description": "D2R farming bot control panel — manage KillZBot remotely from Chrome.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KillZBot Control"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["map_content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-map": {
      "suggested_key": { "default": "Ctrl+Shift+M" },
      "description": "Toggle map overlay"
    },
    "increase-opacity": {
      "suggested_key": { "default": "Ctrl+Shift+Up" },
      "description": "Increase map opacity"
    },
    "decrease-opacity": {
      "suggested_key": { "default": "Ctrl+Shift+Down" },
      "description": "Decrease map opacity"
    }
  },
  "minimum_chrome_version": "88"
}
